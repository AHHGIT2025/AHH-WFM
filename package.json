{
  "name": "ahh-wfm-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:mobile": "npm run dev --workspace=apps/mobile",
    "build:web": "npm run build --workspace=apps/web",
    "build:mobile": "npm run build --workspace=apps/mobile",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "db:generate": "npm run db:generate --workspace=packages/database",
    "db:push": "npm run db:push --workspace=packages/database",
    "diagnose:users": "ts-node -T -P scripts/tsconfig.json scripts/diagnose-orphan-users.ts",
    "cleanup:users": "ts-node -T -P scripts/tsconfig.json scripts/cleanup-orphan-users.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "ts-node": "^10.9.2"
  }
}
