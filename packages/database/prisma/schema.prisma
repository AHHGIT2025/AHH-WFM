}







model Company {
  id              String   @id @default(uuid())
  companyCode     String   @unique
  companyName     String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employees             Employee[]
  departments           Department[]
  costCenters           CostCenter[]
  projects              Project[]
  sites                 ProjectSite[]
  locations             LocationMaster[]
  attendancePolicies    CompanyAttendancePolicy[]
  allowedPunchLocations AllowedPunchLocation[]
  shiftAssignments      ShiftAssignment[]
  attendanceRecords     AttendanceRecord[] @relation("CompanyAttendance")
  onCallAssignments     OnCallAssignment[]
  clearanceRequests     ClearanceRequest[]
}

model CompanyAttendancePolicy {
  id                          String   @id @default(uuid())
  companyId                   String
  company                     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  policyName                  String
  isGeoFencingEnabled         Boolean  @default(true)
  defaultGeofenceRadiusMeters Float    @default(150.0)
  requireSelfie               Boolean  @default(false)
