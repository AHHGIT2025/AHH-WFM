  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model AllowedPunchLocation {
  id                          String   @id @default(uuid())
  companyId                   String
  company                     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                        String
  locationType                String   // OFFICE, PROJECT_SITE, CUSTOM, ON_CALL, CLIENT_SITE
  locationId                  String?
  projectId                   String?
  siteId                      String?
  latitude                    Float
  longitude                   Float
  radiusMeters                Float    @default(150.0)
  address                     String?  @db.Text
  isActive                    Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  employeeAssignments         EmployeeAllowedPunchLocation[]
  attendanceRecords           AttendanceRecord[] @relation("AllowedLocationAttendance")
  onCallAssignments           OnCallAssignment[]
  defaultForEmployees         Employee[] @relation("EmployeeDefaultPunchLocation")
}

model EmployeeAllowedPunchLocation {
  id                     String               @id @default(uuid())
  employeeId             String
  employee               Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  allowedPunchLocationId String
  allowedPunchLocation   AllowedPunchLocation @relation(fields: [allowedPunchLocationId], references: [id], onDelete: Cascade)
  validFrom              DateTime?
  validTo                DateTime?
  priority               Int                  @default(1)
  isDefault              Boolean              @default(false)
  isActive               Boolean              @default(true)
  createdById            String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
}

model OnCallAssignment {
  id                     String               @id @default(uuid())
  companyId              String
  company                Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId             String
  employee               Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  projectId              String?
  project                Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  siteId                 String?
  site                   ProjectSite?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  allowedPunchLocationId String?
  allowedPunchLocation   AllowedPunchLocation? @relation(fields: [allowedPunchLocationId], references: [id], onDelete: SetNull)
  assignmentDate         DateTime
  startTime              String               // "HH:MM"
  endTime                String               // "HH:MM"
  status                 String               @default("STANDBY") // "STANDBY" | "CALLED_OUT" | "COMPLETED" | "CANCELLED"
  description            String?              @db.Text
  createdById            String
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  attendanceRecords      AttendanceRecord[] @relation("OnCallAttendance")
}

model ClearanceRequest {
  id                    String                  @id @default(uuid())
  clearanceNumber       String                  @unique
  formCode              String?                 // e.g. "26-12-2020"
  issueRef              String?                 // e.g. "FM-14-04-02"
  issueDate             String?                 // e.g. "26th DEC, 2020"
  companyId             String?
  company               Company?                @relation(fields: [companyId], references: [id])
  employeeId            String
  employee              Employee                @relation("EmployeeClearance", fields: [employeeId], references: [id], onDelete: Cascade)
  clearanceType         String                  // "LEAVE_VACATION" | "SEPARATION"
  separationType        String?                 // "RESIGNATION" | "TERMINATION" | "END_OF_CONTRACT" | "FINAL_EXIT" | "OTHER"
  linkedLeaveRequestId  String?                 // Reference to LeaveRequest if spawned from leave
  requestedById         String                  // User ID who created it (HR/Admin)
  requestDate           DateTime                @default(now())
  
  // Snapshots
  dateOfJoiningSnapshot String?
  employeeCodeSnapshot  String?
  employeeNameSnapshot  String?
  designationSnapshot   String?
  workingForSnapshot    String?
  qidNumberSnapshot     String?
  qidExpiryDateSnapshot String?
  passportNumberSnapshot     String?
  passportExpiryDateSnapshot String?
  
  // Dates
  departureDate         DateTime?
  returningDate         DateTime?
  lastWorkingDate       DateTime?
  expectedReturnDate    DateTime?
  
  typeOfProcess         String?                 // Copied from form field
  employeeRemarks       String?                 @db.Text
  
  // Employee Signature
  employeeSignedAt      DateTime?
  employeeSignatureName String?
  employeeSignatureData String?                 @db.Text // Optional drawn signature base64
  
  status                String                  @default("DRAFT") // DRAFT, SUBMITTED, PENDING_EMPLOYEE_SIGNATURE, IN_PROGRESS, PENDING_APPROVAL, APPROVED, REJECTED, RETURNED_FOR_CORRECTION, CANCELLED, COMPLETED
  currentStepOrder      Int                     @default(0)
  finalApprovedAt       DateTime?
  completedAt           DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  approvalSteps         ClearanceApprovalStep[]
  history               ClearanceHistory[]
}

model ClearanceTemplate {
  id                    String                     @id @default(uuid())
  name                  String                     @unique // e.g., "Leave / Vacation Clearance", "Separation Clearance"
  clearanceType         String                     // "LEAVE_VACATION" | "SEPARATION"
  description           String?                    @db.Text
  isActive              Boolean                    @default(true)
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  
  sections              ClearanceTemplateSection[]
}

model ClearanceTemplateSection {
  id                    String                     @id @default(uuid())
  templateId            String
  template              ClearanceTemplate          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sectionName           String                     // e.g. "Direct Supervisor", "Finance Department"
  stepOrder             Int
  defaultApproverId     String?                    // Optional specific user ID
  defaultApproverRole   String?                    // Optional specific role string fallback
  isExecutive           Boolean                    @default(false)
  isRequiredByDefault   Boolean                    @default(true)
  conditionalRule       String?                    // e.g. "HAS_IT_ASSETS", "HAS_ACCOMMODATION"
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  checklistItems        ClearanceChecklistItem[]
}

model ClearanceChecklistItem {
  id                    String                     @id @default(uuid())
  sectionId             String
  section               ClearanceTemplateSection   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  itemText              String                     @db.Text
  isRequired            Boolean                    @default(true)
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
}

model ClearanceApprovalStep {
  id                    String                     @id @default(uuid())
  clearanceRequestId    String
  clearanceRequest      ClearanceRequest           @relation(fields: [clearanceRequestId], references: [id], onDelete: Cascade)
  stepOrder             Int
  sectionName           String                     // e.g. "Finance Department"
  isApplicable          Boolean                    @default(true)
  notApplicableReason   String?                    @db.Text
  status                String                     @default("PENDING") // PENDING, APPROVED, REJECTED, RETURNED, SKIPPED, NOT_APPLICABLE
  
  // Routing
  assignedApproverId    String?                    // HR override or default template approver or dynamically resolved supervisor
  assignedApprover      Employee?                  @relation("Approver", fields: [assignedApproverId], references: [id])
  fallbackRole          String?                    // if no explicit approver
  
  // Execution
  notes                 String?                    @db.Text
  remarks               String?                    @db.Text
  signatureName         String?
  signatureDate         DateTime?
  actedAt               DateTime?
  actedById             String?                    // The actual user who took the action
  
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  responses             ClearanceApprovalResponse[]
}

model ClearanceApprovalResponse {
  id                    String                     @id @default(uuid())
  stepId                String
  step                  ClearanceApprovalStep      @relation(fields: [stepId], references: [id], onDelete: Cascade)
  actionType            String                     // "APPROVE", "REJECT", "RETURN", "MARK_NOT_APPLICABLE", "REASSIGN"
  actorId               String                     // User ID who performed the action
  remarks               String?                    @db.Text
  createdAt             DateTime                   @default(now())
}

model ClearanceHistory {
  id                    String                     @id @default(uuid())
  clearanceRequestId    String
  clearanceRequest      ClearanceRequest           @relation(fields: [clearanceRequestId], references: [id], onDelete: Cascade)
  actorId               String                     // User ID who performed the action
  actionType            String                     // "CREATED", "SUBMITTED", "SIGNED", "APPROVED", "REJECTED", "RETURNED", "OVERRIDE_APPLICABILITY", "COMPLETED"
  details               String                     @db.Text
  createdAt             DateTime                   @default(now())
}

// ==========================================
// --- Manpower Operations Additive Models ---
// ==========================================

model UserOperationAccess {
  id                        String   @id @default(uuid())
  employeeId                String   @unique
  employee                  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  allowedWhiteCollar        Boolean  @default(true)
  allowedSecurityGuarding   Boolean  @default(false)
  allowedFacilityManagement Boolean  @default(false)
  defaultLanding            String?
  allowedCompanyIds         Json?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model ManpowerClient {
  id            String             @id @default(uuid())
  name          String
  code          String             @unique
  operationType String             // "SECURITY_GUARDING" | "FACILITY_MANAGEMENT"
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  contracts     ManpowerContract[]
}

model ManpowerContract {
  id                   String                     @id @default(uuid())
  clientId             String
  client               ManpowerClient             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contractNumber       String                     @unique
  title                String
  startDate            DateTime
  endDate              DateTime
  operationType        String                     // "SECURITY_GUARDING" | "FACILITY_MANAGEMENT"
  status               String                     @default("DRAFT") // "DRAFT" | "ACTIVE" | "EXPIRED" | "TERMINATED"
  defaultManpowerCount Int                        @default(0)
  defaultRelieverCount Int                        @default(0)
  shiftDefinitions     Json?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  projects             ManpowerProject[]
  materials            ManpowerContractMaterial[]
}

model ManpowerProject {
  id                     String                                 @id @default(uuid())
  contractId             String
  contract               ManpowerContract                       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  name                   String
  code                   String                                 @unique
  operationType          String                                 // "SECURITY_GUARDING" | "FACILITY_MANAGEMENT"
  isActive               Boolean                                @default(true)
  createdAt              DateTime                               @default(now())
  updatedAt              DateTime                               @updatedAt
  sites                  ManpowerSite[]
  gatePasses             SecurityGatePass[]
  relieverPools          SecurityProjectRelieverPool[]
  coordinatorAssignments SecurityProjectCoordinatorAssignment[]
  siteInspections        SecuritySiteInspection[]
  materials              ManpowerProjectMaterialAllocation[]
}

model ManpowerSite {
  id                     String                                 @id @default(uuid())
  projectId              String
  project                ManpowerProject                        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                   String
  lat                    Float?
  lng                    Float?
  radiusMeters           Float                                  @default(100)
  operationType          String                                 // "SECURITY_GUARDING" | "FACILITY_MANAGEMENT"
  isActive               Boolean                                @default(true)
  gatePassRequired       Boolean                                @default(false)
  gatePassValidationMode String                                 @default("WARNING") // WARNING | STRICT
  clientApprovalRequired Boolean                                @default(false)
  createdAt              DateTime                               @default(now())
  updatedAt              DateTime                               @updatedAt
  locationUnits          ManpowerLocationUnit[]
  shiftRequirements      ManpowerShiftRequirement[]
  gatePasses             SecurityGatePass[]
  relieverPools          SecurityProjectRelieverPool[]
  coordinatorAssignments SecurityProjectCoordinatorAssignment[]
  siteInspections        SecuritySiteInspection[]
}

model ManpowerLocationUnit {
  id                String                     @id @default(uuid())
  siteId            String
  site              ManpowerSite               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name              String
  type              String                     // "GATE" | "POST" | "ZONE" | "AREA" | "FLOOR" | "BLOCK" | "CLEANING_ZONE"
  operationType     String                     // "SECURITY_GUARDING" | "FACILITY_MANAGEMENT"
  isActive          Boolean                    @default(true)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  shiftRequirements ManpowerShiftRequirement[]
}

model ManpowerCategory {
  id                    String                        @id @default(uuid())
  name                  String                        // e.g. "Security Guard", "CCTV Operator", "Cleaner"
  code                  String                        @unique
  operationType         String                        // "SECURITY_GUARDING" | "FACILITY_MANAGEMENT"
  isActive              Boolean                       @default(true)
  isBlueCollar          Boolean                       @default(true)
  isDeployableInRoster  Boolean                       @default(true)
  canWorkOvertime       Boolean                       @default(true)
  requiresMoiLicense    Boolean                       @default(false)
  requiresGatePassCheck Boolean                       @default(false)
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  employees             Employee[]
  shiftRequirements     ManpowerShiftRequirement[]
  relieverPools         SecurityProjectRelieverPool[]
}

model ManpowerShiftRequirement {
  id                    String                 @id @default(uuid())
  siteId                String
  site                  ManpowerSite           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  locationUnitId        String?
  locationUnit          ManpowerLocationUnit?  @relation(fields: [locationUnitId], references: [id], onDelete: SetNull)
  categoryId            String
  category              ManpowerCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  shiftCode             String                 // references Shift.code (e.g. "GEN-001")
  requiredCount         Int
  requiredRelieverCount Int                    @default(0)
  shiftStartTime        String?                // Format: "HH:MM"
  shiftEndTime          String?                // Format: "HH:MM"
  dutyHours             Float?
  operationType         String                 // "SECURITY_GUARDING" | "FACILITY_MANAGEMENT"
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deployments           ManpowerDeployment[]
}

model ManpowerDeployment {
  id                 String                         @id @default(uuid())
  date               DateTime
  shiftRequirementId String
  shiftRequirement   ManpowerShiftRequirement       @relation(fields: [shiftRequirementId], references: [id], onDelete: Cascade)
  operationType      String                         // "SECURITY_GUARDING" | "FACILITY_MANAGEMENT"
  approvalStatus     String                         @default("DRAFT") // "DRAFT" | "SUBMITTED" | "APPROVED" | "REJECTED"
  approvedById       String?
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt
  assignments        ManpowerDeploymentAssignment[]
}

model ManpowerDeploymentAssignment {
  id                    String                       @id @default(uuid())
  deploymentId          String
  deployment            ManpowerDeployment           @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  employeeId            String
  employee              Employee                     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  isReliever            Boolean                      @default(false)
  deploymentType        String                       @default("PERMANENT") // PERMANENT, TEMPORARY, EVENT, OVERTIME, RELIEVER, EMERGENCY_REPLACEMENT
  isOvertime            Boolean                      @default(false)
  overtimeReason        String?
  sourceType            String                       @default("GENERAL_POOL") // FIXED_RELIEVER, SITE_RELIEVER, GENERAL_POOL, EMERGENCY, OJT, FOC
  permanentDeploymentId String?
  validationWarnings    Json?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  relieverAssignments   ManpowerRelieverAssignment[] @relation("OriginalAssignment")
}

model ManpowerRelieverAssignment {
  id                   String                       @id @default(uuid())
  originalAssignmentId String
  originalAssignment   ManpowerDeploymentAssignment @relation("OriginalAssignment", fields: [originalAssignmentId], references: [id], onDelete: Cascade)
  relieverEmployeeId   String
  relieverEmployee     Employee                     @relation(fields: [relieverEmployeeId], references: [id], onDelete: Cascade)
  reason               String?
  status               String                       @default("APPROVED") // "PENDING" | "APPROVED"
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
}

model SecurityLicense {
  id             String    @id @default(uuid())
  employeeId     String    @unique
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  licenseType    String    @default("MOI") // "MOI" or other
  licenseNumber  String
  issueDate      DateTime
  expiryDate     DateTime
  status         String    @default("VALID") // "VALID" | "EXPIRING_SOON" | "EXPIRED" | "NOT_AVAILABLE"
  documentUrl    String?
  remarks        String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SecurityGatePass {
  id             String          @id @default(uuid())
  employeeId     String
  employee       Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  projectId      String
  project        ManpowerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  siteId         String
  site           ManpowerSite    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  gatePassNumber String
  issueDate      DateTime
  expiryDate     DateTime
  status         String          @default("VALID") // "VALID" | "EXPIRING_SOON" | "EXPIRED" | "PENDING" | "NOT_REQUIRED"
  documentUrl    String?
  remarks        String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([employeeId, siteId])
}

model SecurityProjectRelieverPool {
  id                    String                              @id @default(uuid())
  projectId             String
  project               ManpowerProject                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  siteId                String?
  site                  ManpowerSite?                       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  requiredRelieverCount Int                                 @default(0)
  categoryId            String
  category              ManpowerCategory                    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  isActive              Boolean                             @default(true)
  createdAt             DateTime                            @default(now())
  updatedAt             DateTime                            @updatedAt
  assignments           SecurityProjectRelieverAssignment[]
}

model SecurityProjectRelieverAssignment {
  id             String                      @id @default(uuid())
  relieverPoolId String
  relieverPool   SecurityProjectRelieverPool @relation(fields: [relieverPoolId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       Employee                    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate      DateTime
  endDate        DateTime?
  isActive       Boolean                     @default(true)
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
}

model SecurityProjectCoordinatorAssignment {
  id                    String          @id @default(uuid())
  coordinatorEmployeeId String
  coordinator           Employee        @relation(fields: [coordinatorEmployeeId], references: [id], onDelete: Cascade)
  projectId             String
  project               ManpowerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  siteId                String?
  site                  ManpowerSite?   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  startDate             DateTime
  endDate               DateTime?
  isActive              Boolean         @default(true)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model SecuritySiteInspection {
  id                    String          @id @default(uuid())
  coordinatorEmployeeId String
  coordinator           Employee        @relation(fields: [coordinatorEmployeeId], references: [id], onDelete: Cascade)
  projectId             String
  project               ManpowerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  siteId                String
  site                  ManpowerSite    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  inspectionDate        DateTime
  status                String          // "COMPLETED" | "PENDING"
  remarks               String?         @db.Text
  followUpRequired      Boolean         @default(false)
  followUpStatus        String          @default("NONE") // "NONE" | "PENDING" | "RESOLVED"
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model ManpowerContractMaterial {
  id            String                     @id @default(uuid())
  contractId    String
  contract      ManpowerContract           @relation(fields: [contractId], references: [id], onDelete: Cascade)
  itemName      String
  quantity      Int
  startDate     DateTime
  endDate       DateTime
  operationType String                     // "SECURITY_GUARDING" | "FACILITY_MANAGEMENT"
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  allocations   ManpowerProjectMaterialAllocation[]
}

model ManpowerProjectMaterialAllocation {
  id            String                     @id @default(uuid())
  materialId    String
  material      ManpowerContractMaterial   @relation(fields: [materialId], references: [id], onDelete: Cascade)
  projectId     String
  project       ManpowerProject            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quantity      Int
  startDate     DateTime
  endDate       DateTime
  operationType String                     // "SECURITY_GUARDING" | "FACILITY_MANAGEMENT"
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
}
