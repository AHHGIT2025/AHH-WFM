  code                String     @unique
  name                String
  description         String?    @db.Text
  linkedDesignationId String?
  isActive            Boolean    @default(true)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  employees           Employee[]
}

model LocationMaster {
