datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

model Employee {
  id            String               @id
  name          String
  department    String               // Keeps compatibility name
  companyId     String?
  company       Company?             @relation(fields: [companyId], references: [id])
  departmentId  String?
  departmentRef Department?          @relation(fields: [departmentId], references: [id])
  role          String               // "ADMIN" | "SUPERVISOR" | "EMPLOYEE"
  status        String               // "On Duty" | "On Break" | "Offline" | "On Leave"
  email         String               @unique
  phone         String?
  shiftId       String?
  passwordHash  String?
  profilePhotoUrl       String?
  profilePhotoUpdatedAt DateTime?
  isActive      Boolean              @default(true)
  employmentStatus String            @default("ACTIVE")
  dutyStatus    String               @default("OFF_DUTY")
  employeeCategory String            @default("WHITE_COLLAR")
  workAssignmentType String          @default("OFFICE_BASED")
  dateOfJoining      DateTime?
  qidNumber          String?
  qidExpiryDate      DateTime?
  passportNumber     String?
  passportExpiryDate DateTime?
  passportIssueDate  DateTime?
  passportIssuingCountry String?
  sponsor            String?
  hasAccommodation   Boolean         @default(false)
  hasItAssets        Boolean         @default(false)
  attendance    AttendanceRecord[]
  leaves        LeaveRequest[]
  leaveBalances LeaveBalance[]
  ledgers       LeaveBalanceLedger[]
  shiftAssignments ShiftAssignment[]
  positionCategoryId String?
  positionCategory   BlueCollarPositionCategory? @relation(fields: [positionCategoryId], references: [id])
  defaultProjectId   String?
  defaultProject     Project?                    @relation("DefaultProject", fields: [defaultProjectId], references: [id])
  defaultSiteId      String?
  defaultSite        ProjectSite?                @relation("DefaultSite", fields: [defaultSiteId], references: [id])
  deployments        EmployeeDeployment[]
  designationId      String?
  designation        Designation?                @relation(fields: [designationId], references: [id])
  tradeClassificationId String?
  tradeClassification   TradeClassification?      @relation(fields: [tradeClassificationId], references: [id])
  costCenterId       String?
  costCenterRef      CostCenter?                 @relation(fields: [costCenterId], references: [id])
  defaultLocationId  String?
  defaultLocation    LocationMaster?             @relation("DefaultLocation", fields: [defaultLocationId], references: [id])
  officeLocationId   String?
  officeLocation     LocationMaster?             @relation("OfficeLocation", fields: [officeLocationId], references: [id])
  isRelieverEligible Boolean                     @default(false)
  isStandbyEligible  Boolean                     @default(false)

  defaultPunchLocationId       String?
  defaultPunchLocation         AllowedPunchLocation? @relation("EmployeeDefaultPunchLocation", fields: [defaultPunchLocationId], references: [id])
  allowMultiplePunchLocations  Boolean               @default(false)
  allowOfficePunch             Boolean               @default(true)
  allowProjectSitePunch        Boolean               @default(true)
  allowOnCallPunch             Boolean               @default(false)
  allowOutOfZonePunch          Boolean               @default(false)
  requireOutOfZoneReview       Boolean               @default(true)
  geofenceRadiusOverrideMeters Float?

  allowedPunchLocations EmployeeAllowedPunchLocation[]
  onCallAssignments     OnCallAssignment[]

  // --- Supervisor Hierarchy ---
  immediateSupervisorId String?
  immediateSupervisor   Employee?  @relation("ImmediateSupervisor", fields: [immediateSupervisorId], references: [id])
  subordinates          Employee[] @relation("ImmediateSupervisor")
  
  reportingManagerId    String?
  projectSupervisorId   String?
  siteSupervisorId      String?
  isSupervisor          Boolean    @default(false)
  supervisorScopeType   String     @default("DIRECT_REPORTS") // DIRECT_REPORTS, DEPARTMENT, COMPANY, PROJECT, SITE, CUSTOM
  
  // --- User Account & Auth (Instead of separate UserAccount table) ---
  // TODO: Consider migrating these fields to a dedicated UserAccount table in the future
  username              String?    @unique
  authMode              String     @default("LOCAL") // LOCAL, SSO, LOCAL_AND_SSO
  ssoProvider           String?
  ssoSubject            String?
  isLoginEnabled        Boolean    @default(true)
  mustChangePassword    Boolean    @default(false)
  isLocked              Boolean    @default(false)
  failedLoginAttempts   Int        @default(0)
  selfServiceEnabled    Boolean    @default(true)
  lastLoginAt           DateTime?
  passwordUpdatedAt     DateTime?


  webAccessEnabled      Boolean    @default(true)
  mobileAccessEnabled   Boolean    @default(true)
  usernameStrategy      String     @default("MANUAL")
  deactivatedAt         DateTime?

  clearanceRequests     ClearanceRequest[] @relation("EmployeeClearance")
  clearanceApprovals    ClearanceApprovalStep[] @relation("Approver")

  // --- Manpower Operations Additions ---
  operationType         String                     @default("WHITE_COLLAR") // "WHITE_COLLAR" | "SECURITY_GUARDING" | "FACILITY_MANAGEMENT"
  manpowerCategoryId    String?
  manpowerCategory      ManpowerCategory?          @relation(fields: [manpowerCategoryId], references: [id], onDelete: SetNull)
  userOperationAccess   UserOperationAccess?
  manpowerAssignments   ManpowerDeploymentAssignment[]
  manpowerRelievers     ManpowerRelieverAssignment[]
  securityLicense       SecurityLicense?
  securityGatePasses    SecurityGatePass[]
  relieverAssignments   SecurityProjectRelieverAssignment[]
  coordinatorAssignments SecurityProjectCoordinatorAssignment[]
  siteInspections       SecuritySiteInspection[]
}

model Department {
  id        String     @id @default(uuid())
  companyId String?
  company   Company?   @relation(fields: [companyId], references: [id])
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
}

model AttendanceRecord {
  id                 String                 @id @default(uuid())
  employeeId         String
  employeeName       String
  companyId          String?
  company            Company?               @relation("CompanyAttendance", fields: [companyId], references: [id])
  checkIn            DateTime               @default(now())
  checkOut           DateTime?
  originalCheckIn    DateTime               @default(now())
  originalCheckOut   DateTime?
  lat                Float
  lng                Float
  device             String
  status             String                 // "ON_TIME" | "LATE" | "OUT_OF_ZONE" | "ABSENT" | "PENDING_CORRECTION" | "CORRECTED"
  locationName       String
  worksiteId         String?
  worksite           Worksite?              @relation(fields: [worksiteId], references: [id], onDelete: SetNull)
  shiftId            String?
  shiftStartSnapshot String?
  shiftEndSnapshot   String?
  lateMinutes        Int                    @default(0)
  standardOtMinutes  Int                    @default(0)
  weekendOtMinutes   Int                    @default(0)
  holidayOtMinutes   Int                    @default(0)
  nightOtMinutes     Int                    @default(0)
  specialEventOtMinutes Int                 @default(0)
  otApprovedMinutes  Int                    @default(0)
  overtimePayAmount  Float                  @default(0.0)
  otStatus           String                 @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"
  employee           Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  corrections        AttendanceCorrection[]
  projectId          String?
  siteId             String?
  deploymentId       String?
  projectStatusFlag  String?
  officeLocationId   String?
  onCallAssignmentId String?
  onCallAssignment   OnCallAssignment?      @relation("OnCallAttendance", fields: [onCallAssignmentId], references: [id], onDelete: SetNull)
  allowedPunchLocationId String?
  allowedPunchLocation AllowedPunchLocation? @relation("AllowedLocationAttendance", fields: [allowedPunchLocationId], references: [id], onDelete: SetNull)
  punchLocationType  String?
}

model Worksite {
  id                String             @id @default(uuid())
  name              String             @unique
  lat               Float
  lng               Float
  radiusMeters      Float
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendanceRecords AttendanceRecord[]
}

model AttendanceCorrection {
  id                 String           @id @default(uuid())
  attendanceRecordId String
  attendanceRecord   AttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)
  requestedCheckIn   DateTime?
  requestedCheckOut  DateTime?
  reason             String           @db.Text
  status             String           // "Pending" | "Approved" | "Rejected"
  reviewedById       String?
  reviewNotes        String?          @db.Text
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Shift {
  id            String @id
  name          String
  code          String @unique
  timeRange     String
  breakDuration String
  status        String // "Active" | "Inactive"
}

model LeaveType {
  id                      String         @id @default(uuid())
  name                    String         @unique // e.g. "Annual Leave"
  code                    String         @unique // e.g. "ANNUAL"
  isActive                Boolean        @default(true)
  accruable               Boolean        @default(true)
  carryForward            Boolean        @default(true)
  maxCarryOver            Float          @default(0.0)
  expiryMonths            Int            @default(12)
  colorCode               String         @default("#0058be")
  sapExternalId           String?        @unique
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  balances                LeaveBalance[]
  requests                LeaveRequest[]
  ledgers                 LeaveBalanceLedger[]

  // v0.18.4 fields
  description             String?
  isPaid                  Boolean        @default(true)
  requiresDocument        Boolean        @default(false)
  workflowCode            String?
  defaultAnnualAllocation Float?
  maxDaysPerRequest       Float?
  allowHalfDay            Boolean        @default(true)
  allowCarryForward       Boolean        @default(true)
  carryForwardLimit       Float?
  genderRestriction       String         @default("ALL")
  applicableAfterProbation Boolean       @default(true)
}

model LeaveBalance {
  id                 String       @id @default(uuid())
  employeeId         String
  employee           Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId        String
  leaveType          LeaveType    @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  allocatedDays      Float        @default(0.0)
  usedDays           Float        @default(0.0)
  pendingDays        Float        @default(0.0)
  carriedOver        Float        @default(0.0)
  sapExternalId      String?      @unique
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // v0.18.4 fields
  year               Int          @default(2026) // Runtime uses new Date().getFullYear(); default is for DDL safety
  carriedForwardDays Float        @default(0.0)
  adjustmentDays     Float        @default(0.0)
  remarks            String?

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveBalanceLedger {
  id            String    @id @default(uuid())
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId   String
  leaveType     LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  actionType    String    // "INITIAL" | "ACCRUAL" | "LEAVE_TAKEN" | "CARRY_FORWARD" | "EXPIRY" | "MANUAL_ADJUSTMENT"
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  referenceId   String?
  remarks       String?
  createdAt     DateTime  @default(now())
}

model LeaveRequest {
  id                    String                 @id @default(uuid())
  employeeId            String
  employeeName          String
  type                  String
  dateRange             String
  reason                String
  status                String                 // "Approved" | "Rejected" | "Pending Approval"
  startDate             DateTime?
  endDate               DateTime?
  totalDays             Float?
  leaveTypeId           String?
  leaveType             LeaveType?             @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  employee              Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  currentStep           Int                    @default(1)
  totalSteps            Int                    @default(1)
  workflowId            String?
  submittedAt           DateTime               @default(now())
  firstActionAt         DateTime?
  approvedAt            DateTime?
  approvalDurationHours Float?
  escalationCount       Int                    @default(0)
  relieverRequired      Boolean                @default(false)
  relieverAssignmentId  String?
  approvalHistory       LeaveApprovalHistory[]
}

model LeaveApprovalWorkflow {
  id            String              @id @default(uuid())
  name          String
  description   String?
  isActive      Boolean             @default(true)
  conditionExpr String?             @db.Text // JSON configuration string
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  steps         LeaveApprovalStep[]
}

model LeaveApprovalStep {
  id                  String                @id @default(uuid())
  workflowId          String
  workflow            LeaveApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepNumber          Int
  roleRequired        String                // "SUPERVISOR" | "MANAGER" | "HR"
  autoApprove         Boolean               @default(false)
  departmentFilter    String?
  gradeFilter         String?
  employeeGroupFilter String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@unique([workflowId, stepNumber])
}

model LeaveApprovalHistory {
  id             String       @id @default(uuid())
  leaveRequestId String
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  approverId     String?      // Email or User ID, null if SYSTEM auto-approved
  action         String       // "SUBMIT" | "APPROVE" | "REJECT" | "ESCALATE" | "REMIND" | "AUTO_APPROVE"
  remarks        String?      @db.Text
  previousStatus String
  newStatus      String
  createdAt      DateTime     @default(now())
}

model LeaveApprovalDelegation {
  id                 String   @id @default(uuid())
  employeeId         String   // Original approver employeeId
  delegateApproverId String   // Delegate employeeId
  validFrom          DateTime
  validTo            DateTime
  reason             String   @db.Text
  createdAt          DateTime @default(now())
}

model Holiday {
  id          String   @id @default(uuid())
  name        String
  date        DateTime @unique
  isRecurring Boolean  @default(false)
  scope       String   // "NATIONAL" | "COMPANY" | "SITE"
  siteId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SapMapping {
  id                 String @id
  sourceField        String
  targetField        String
  transformationRule String
  status             String // "Mapped" | "Conflict" | "Unmapped"
}

model SyncLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  operation String
  subject   String
  status    String   // "Success" | "Failed" | "Warning"
  details   String
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  timestamp DateTime @default(now())
  author    String
  category  String   // "General" | "Urgent" | "System Update"
}

model ShiftTemplate {
  id          String            @id @default(uuid())
  name        String
  startTime   String            // "08:00"
  endTime     String            // "17:00"
  isSplit     Boolean           @default(false)
  splitStart  String?           // "16:00"
  splitEnd    String?           // "20:00"
  isFlexible  Boolean           @default(false)
  coreHours   Float?            // 8.0
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  assignments ShiftAssignment[]
}

model RotationTemplate {
  id          String   @id @default(uuid())
  name        String
  cycleDays   Int
  patternJson String   @db.Text // JSON list of shiftTemplateIds or "REST"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ShiftAssignment {
  id              String        @id @default(uuid())
  companyId       String?
  company         Company?      @relation(fields: [companyId], references: [id])
  employeeId      String
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftTemplateId String
  shiftTemplate   ShiftTemplate @relation(fields: [shiftTemplateId], references: [id])
  date            DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  projectId       String?
  siteId          String?
  officeLocationId String?
  isSplitShift    Boolean       @default(false)
  parentAssignmentId String?
  relieverRequired   Boolean    @default(false)
  relieverAssignmentId String?
  assignmentStatus   String     @default("ACTIVE") // "ACTIVE", "INACTIVE", "CANCELLED"

  @@index([employeeId])
}

model ShiftSwapRequest {
  id                String          @id @default(uuid())
  requestorId       String
  targetEmployeeId  String
  requestorShiftId  String
  targetShiftId     String
  status            String          // "PENDING", "APPROVED", "REJECTED"
  reason            String?
  reviewNotes       String?
  approvedById      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model OvertimeRate {
  id                 String          @id @default(uuid())
  name               String
  overtimeType       String          // "STANDARD_OT" | "WEEKEND_OT" | "HOLIDAY_OT" | "NIGHT_OT" | "SPECIAL_EVENT_OT"
  multiplier         Float
  fixedRateAmount    Float?
  currency           String          @default("QAR")
  appliesOnWeekend   Boolean         @default(false)
  appliesOnHoliday   Boolean         @default(false)
  appliesAfterMinutes Int            @default(0)
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model SapConnection {
  id                String    @id @default(uuid())
  systemName        String    @unique
  odataUrl          String
  clientId          String
  companyId         String
  userId            String
  privateKeyVaultId String
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  syncJobs          SapSyncJob[]
}

model SapSyncJob {
  id              String       @id @default(uuid())
  connectionId    String
  connection      SapConnection @relation(fields: [connectionId], references: [id])
  module          String       // "EMPLOYEE" | "LEAVE" | "ATTENDANCE" | "OVERTIME" | "ROSTER"
  syncType        String       // "FULL" | "INCREMENTAL" | "MANUAL"
  status          String       // "PENDING" | "PROCESSING" | "COMPLETED" | "FAILED"
  recordsProcessed Int         @default(0)
  recordsSucceeded Int         @default(0)
  recordsFailed    Int         @default(0)
  startedAt       DateTime     @default(now())
  completedAt     DateTime?
  errorMessage    String?      @db.Text
  deltaToken      String?
  logs            SapSyncLog[]
}

model SapSyncLog {
  id            String      @id @default(uuid())
  jobId         String
  job           SapSyncJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  severity      String      // "INFO" | "WARN" | "ERROR"
  entityName    String?     // e.g. "Employee", "Department"
  entityId      String?
  message       String      @db.Text
  createdAt     DateTime    @default(now())
}

model SapFieldMapping {
  id            String      @id @default(uuid())
  module        String      // "EMPLOYEE" | "LEAVE" | "ATTENDANCE"
  sourceField   String
  targetField   String
  transformRule String?
  validationRules String?
  isRequired    Boolean     @default(false)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model SapRetryQueue {
  id            String      @id @default(uuid())
  module        String      // "EMPLOYEE" | "LEAVE" | "ATTENDANCE"
  entityId      String
  payload       String      @db.Text
  retryCount    Int         @default(0)
  nextAttemptAt DateTime
  lastError     String?     @db.Text
  status        String      @default("PENDING") // "PENDING" | "FAILED_DLQ" | "RESOLVED"
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model SapExportQueue {
  id              String      @id @default(uuid())
  module          String      // "LEAVE" | "ATTENDANCE" | "OVERTIME" | "ROSTER"
  recordId        String
  payload         String      @db.Text
  status          String      @default("PENDING") // "PENDING" | "PROCESSING" | "SENT" | "FAILED"
  idempotencyKey  String      @unique
  sapAckId        String?
  sapAckStatus    String?
  sapAckTimestamp DateTime?
  retryCount      Int         @default(0)
  lastError       String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model SapPayrollStage {
  id              String      @id @default(uuid())
  employeeId      String
  payrollPeriod   String      // e.g. "2026-06"
  wageType        String      // e.g. "WT_OT_STD", "WT_OT_WKD"
  calculatedHours Float
  calculatedPay   Float       // Base currency QAR
  isApproved      Boolean     @default(false)
  isExported      Boolean     @default(false)
  exportedJobId   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@unique([employeeId, payrollPeriod, wageType])
}

model SapReconciliationLog {
  id            String      @id @default(uuid())
  employeeId    String
  period        String      // e.g. "2026-06"
  module        String      // "LEAVE" | "ATTENDANCE" | "OVERTIME"
  wfmHours      Float       // Local WFM record sum
  sapHours      Float       // Queried SAP OData sum
  discrepancy   Float       // Math difference (WFM - SAP)
  status        String      @default("MATCHED") // "MATCHED" | "DISCREPANCY" | "RESOLVED"
  comments      String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model SapPayrollPeriodLock {
  id            String      @id @default(uuid())
  period        String      @unique // e.g. "2026-06"
  locked        Boolean     @default(false)
  lockedById    String?
  lockedAt      DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model SavedReport {
  id          String   @id @default(uuid())
  name        String
  reportType  String
  filtersJson String   @db.Text
  createdById String
  isShared    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ReportExportLog {
  id           String   @id @default(uuid())
  reportType   String
  exportFormat String
  filtersJson  String   @db.Text
  fileName     String
  filePath     String
  fileSize     Int
  exportedById String
  createdAt    DateTime @default(now())
}

model UserActivityLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String
  beforeJson String?  @db.Text
  afterJson  String?  @db.Text
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

model ProductionCheckLog {
  id           String   @id @default(uuid())
  checkName    String
  category     String
  status       String
  resultJson   String   @db.Text
  checkedById  String?
  checkedAt    DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BackupJob {
  id           String    @id @default(uuid())
  backupType   String
  status       String    // PENDING, PROCESSING, COMPLETED, FAILED
  fileName     String
  filePath     String
  fileSize     Int
  checksum     String
  createdById  String
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  errorMessage String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model BackupAuditLog {
  id           String   @id @default(uuid())
  backupJobId  String
  action       String   // BACKUP_CREATED, BACKUP_DOWNLOADED, BACKUP_FAILED, BACKUP_DELETED, RESTORE_REQUESTED
  performedById String
  ipAddress    String?
  userAgent    String?
  details      String   @db.Text
  createdAt    DateTime @default(now())
}

model EmployeeBulkUploadJob {
  id              String    @id @default(uuid())
  fileName        String
  status          String    // PENDING, PROCESSING, COMPLETED, FAILED
  totalRows       Int
  validRows       Int
  invalidRows     Int
  importedRows    Int
  failedRows      Int
  uploadedById    String
  errorReportPath String?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  errorMessage    String?   @db.Text
}

model SystemRole {
  id              String    @id @default(uuid())
  name            String    @unique
  description     String?
  isSystemDefault Boolean   @default(false)
  isActive        Boolean   @default(true)
  isEditable      Boolean   @default(true)
  scope           String?   @default("Global")
  roleType        String    @default("White Collar Operations")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model SystemPermission {
  id        String   @id @default(uuid())
  key       String   @unique
  label     String
  module    String
  pagePath  String?
  action    String?
  createdAt DateTime @default(now())
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  canView      Boolean  @default(false)
  canCreate    Boolean  @default(false)
  canEdit      Boolean  @default(false)
  canDelete    Boolean  @default(false)
  canApprove   Boolean  @default(false)
  canExport    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserRoleAssignment {
  id           String   @id @default(uuid())
  employeeId   String
  roleId       String
  assignedById String
  assignedAt   DateTime @default(now())
  isActive     Boolean  @default(true)
}

model BlueCollarPositionCategory {
