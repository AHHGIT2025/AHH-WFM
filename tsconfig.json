{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@ahh-wfm/types": ["packages/types/src"],
      "@ahh-wfm/mock-data": ["packages/mock-data/src"],
      "@ahh-wfm/ui/*": ["packages/ui/src/*"]
    }
  },
  "exclude": ["node_modules"]
}
